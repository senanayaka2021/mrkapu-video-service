{
  "name": "mrkapu-video-service",
  "version": "0.0.1",
  "description": "Standalone services service extracted from mrkapu-back-end",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:lambda": "yarn build",
    "deploy:video": "yarn build && serverless deploy",
    "deploy:lambda": "yarn deploy:video",
    "remove:video": "serverless remove",
    "remove:lambda": "yarn remove:video",
    "offline": "yarn build && serverless offline",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "start:lambda": "node -e \"const { handler } = require('./dist/lambda'); handler({ rawPath: '/', requestContext: { http: { method: 'GET' } } }, {}, console.log).then(console.log).catch(console.error)\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1000.0",
    "@aws-sdk/client-eventbridge": "^3.1027.0",
    "@aws-sdk/client-s3": "^3.980.0",
    "@aws-sdk/client-sesv2": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.980.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mongoose": "^11.0.3",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@types/bcrypt": "^5.0.2",
    "@vendia/serverless-express": "^4.12.6",
    "bcrypt": "^6.0.0",
    "class-validator": "^0.14.2",
    "firebase-admin": "^13.4.0",
    "mongoose": "^8.15.1",
    "nodemailer": "^7.0.12",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.1",
    "twilio": "^5.7.1",
    "typeorm": "^0.3.24",
    "uuid": "^13.0.0",
    "@codegenie/serverless-express": "^4.17.1",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.42.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "serverless-jetpack": "^0.11.2",
    "serverless-offline": "^14.4.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3",
    "serverless": "^4.34.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "packageManager": "yarn@1.22.21"
}
